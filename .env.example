# 開発用（必要に応じて .env にコピーして編集）
SECRET_KEY=dev-secret-key-at-least-32-chars-required

# PostgreSQL（Docker Compose で 4 サービスが共通利用・DB 分離）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# サービス間認証（Service JWT）。全サービスで同一のシークレットを共有すること。
SERVICE_JWT_SECRET=dev-service-jwt-secret-change-in-production

# 監査・索引送信先（立法・執行から）。未設定時は送信しない（Issue #8, #10）。
# ROOT_SERVICE_URL=http://root:8080

# 他サービス URL（finalize 時に承認取得用・Issue #10）。立法は judiciary/executive、執行は judiciary/legislative を参照。
# JUDICIARY_SERVICE_URL=http://judiciary:8080
# LEGISLATIVE_SERVICE_URL=http://legislative:8080
# EXECUTIVE_SERVICE_URL=http://executive:8080

# 本番用（docker-compose.prod.yml 利用時は必須。カンマ区切りでホスト名を指定）
# ALLOWED_HOSTS=example.com,api.example.com
